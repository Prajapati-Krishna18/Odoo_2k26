            }
          },
          "response": []
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Department (Soft)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}"]
            }
