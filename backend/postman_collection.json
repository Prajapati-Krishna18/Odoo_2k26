{
  "info": {
    "name": "AssetFlow — ERP System APIs",
    "description": "Auth, RBAC, Organisation Setup, Dashboard, Notifications, Activity Logs, Global Search, and Shared Upload endpoints for the AssetFlow ERP system.",
