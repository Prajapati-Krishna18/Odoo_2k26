// ─────────────────────────────────────────────────────────────
// AssetFlow — Prisma Schema
// Phase 3: Organization Setup
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  DAMAGED
}

// ── Role ─────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

// ── User ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  fullName      String    @map("full_name")
  email         String    @unique
  password      String
  phone         String
  profileImage  String?   @map("profile_image")
  roleId        String    @map("role_id")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Organization Setup fields
  employeeCode String?   @unique @map("employee_code")
  departmentId String?   @map("department_id")
  designation  String?
  joiningDate  DateTime? @map("joining_date")

  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  // Relations
  department       Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDepartment Department? @relation("DepartmentHead")

  @@map("users")
}

// ── Refresh Token ────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Department ───────────────────────────────────────────────

model Department {
  id                 String           @id @default(uuid())
  name               String
  code               String           @unique
  description        String?
  parentDepartmentId String?          @map("parent_department_id")
  departmentHeadId   String?          @unique @map("department_head_id")
  status             DepartmentStatus @default(ACTIVE)
  isDeleted          Boolean          @default(false) @map("is_deleted")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // Relations
  parentDepartment Department?  @relation("SubDepartments", fields: [parentDepartmentId], references: [id])
  childDepartments Department[] @relation("SubDepartments")
  departmentHead   User?        @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  employees        User[]       @relation("DepartmentEmployees")

  @@map("departments")
}

// ── Asset Category ───────────────────────────────────────────

model AssetCategory {
  id               String         @id @default(uuid())
  name             String         @unique
  description      String?
  icon             String?
  requiresWarranty Boolean        @default(false) @map("requires_warranty")
  status           CategoryStatus @default(ACTIVE)
  isDeleted        Boolean        @default(false) @map("is_deleted")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_categories")
}

// ── Asset ───────────────────────────────────────────────────────

model Asset {
  id             String         @id @default(uuid())
  assetTag       String         @unique @map("asset_tag")
  serialNumber   String         @unique @map("serial_number")
  assetName      String         @map("asset_name")
  description    String?
  manufacturer   String?
  modelNumber    String?        @map("model_number")
  purchaseDate   DateTime?      @map("purchase_date")
  purchaseCost   Decimal?       @map("purchase_cost") @db.Decimal(10, 2)
  warrantyExpiry DateTime?      @map("warranty_expiry")
  location       String?
  status         AssetStatus    @default(AVAILABLE)
  condition      AssetCondition @default(NEW)
  qrCode         String?        @map("qr_code")
  ownerId        String?        @map("owner_id")
  departmentId   String?        @map("department_id")
  categoryId     String?        @map("category_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  category AssetCategory? @relation(fields: [categoryId], references: [id])
  images   AssetImage[]
  history  AssetHistory[]

  @@index([assetTag])
  @@index([serialNumber])
  @@index([categoryId])
  @@index([status])
  @@map("assets")
}

// ── Asset Image ──────────────────────────────────────────────────

model AssetImage {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_images")
}

// ── Asset History ────────────────────────────────────────────────

model AssetHistory {
  id          String   @id @default(uuid())
  assetId     String   @map("asset_id")
  action      String
  remarks     String?
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_history")
}
