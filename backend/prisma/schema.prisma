// ─────────────────────────────────────────────────────────────
// AssetFlow — Prisma Schema
// Merged Schema: Phase 3 + Phase 6
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ResourceType {
  MEETING_ROOM
  VEHICLE
  EQUIPMENT
}

enum ResourceStatus {
  AVAILABLE
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum MaintenanceStatus {
  REQUESTED
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_APPROVED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  MAINTENANCE_STARTING_SOON
  MAINTENANCE_COMPLETED
}

// ── Role ─────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// ── User ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  fullName      String    @map("full_name")
  email         String    @unique
  password      String
  phone         String
  profileImage  String?   @map("profile_image")
  roleId        String    @map("role_id")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Organization Setup fields
  employeeCode String?   @unique @map("employee_code")
  departmentId String?   @map("department_id")
  designation  String?
  joiningDate  DateTime? @map("joining_date")

  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  bookings      Booking[]
  notifications Notification[]

  maintenanceRequested MaintenanceRequest[] @relation("RequestedBy")
  maintenanceApproved  MaintenanceRequest[] @relation("ApprovedBy")

  // Relations
  department       Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDepartment Department? @relation("DepartmentHead")

  // Shared Infrastructure relations
  activityLogs  ActivityLog[]

  @@map("users")
}

// ── Refresh Token ────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Department ───────────────────────────────────────────────

model Department {
  id                 String           @id @default(uuid())
  name               String
  code               String           @unique
  description        String?
  parentDepartmentId String?          @map("parent_department_id")
  departmentHeadId   String?          @unique @map("department_head_id")
  status             DepartmentStatus @default(ACTIVE)
  isDeleted          Boolean          @default(false) @map("is_deleted")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // Relations
  parentDepartment Department?  @relation("SubDepartments", fields: [parentDepartmentId], references: [id])
  childDepartments Department[] @relation("SubDepartments")
  departmentHead   User?        @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  employees        User[]       @relation("DepartmentEmployees")

  @@map("departments")
}

// ── Asset Category ───────────────────────────────────────────

model AssetCategory {
  id               String         @id @default(uuid())
  name             String         @unique
  description      String?
  icon             String?
  requiresWarranty Boolean        @default(false) @map("requires_warranty")
  status           CategoryStatus @default(ACTIVE)
  isDeleted        Boolean        @default(false) @map("is_deleted")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@map("asset_categories")
}

// ── Activity Log ─────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   // e.g. "LOGIN", "LOGOUT", "CREATE", "UPDATE", "ROLE_CHANGE"
  module      String   // e.g. "AUTH", "DEPARTMENT", "EMPLOYEE"
  entityId    String?  @map("entity_id")
  description String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ── Resource ─────────────────────────────────────────────────

model Resource {
  id          String         @id @default(uuid())
  name        String
  type        ResourceType
  status      ResourceStatus @default(AVAILABLE)
  description String?
  location    String?
  capacity    Int?
  quantity    Int            @default(1)
  imageUrl    String?        @map("image_url")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]

  @@index([type])
  @@index([status])
  @@map("resources")
}

// ── Booking ──────────────────────────────────────────────────

model Booking {
  id             String        @id @default(uuid())
  resourceId     String        @map("resource_id")
  userId         String        @map("user_id")
  title          String
  description    String?
  startTime      DateTime      @map("start_time")
  endTime        DateTime      @map("end_time")
  status         BookingStatus @default(PENDING)
  rejectedReason String?       @map("rejected_reason")
  cancelReason   String?       @map("cancel_reason")
  attendeeCount  Int?          @map("attendee_count")
  purpose        String?
  returnCondition String?      @map("return_condition")
  isExclusive    Boolean       @default(true) @map("is_exclusive")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  resource      Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([resourceId])
  @@index([userId])
  @@index([startTime, endTime])
  @@index([status])
  @@map("bookings")
}

// ── Maintenance Request ──────────────────────────────────────

model MaintenanceRequest {
  id              String            @id @default(uuid())
  resourceId      String            @map("resource_id")
  requestedById   String            @map("requested_by_id")
  approvedById    String?           @map("approved_by_id")
  title           String
  description     String
  priority        Priority          @default(MEDIUM)
  status          MaintenanceStatus @default(REQUESTED)
  scheduledStart  DateTime?         @map("scheduled_start")
  scheduledEnd    DateTime?         @map("scheduled_end")
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  rejectedReason  String?           @map("rejected_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  resource      Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  requestedBy   User           @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?          @relation("ApprovedBy", fields: [approvedById], references: [id])
  notifications Notification[]

  @@index([resourceId])
  @@index([requestedById])
  @@index([status])
  @@index([priority])
  @@map("maintenance_requests")
}

// ── Notification ─────────────────────────────────────────────

model Notification {
  id                   String           @id @default(uuid())
  userId               String           @map("user_id")
  type                 String           @default("INFO")
  title                String
  message              String
  isRead               Boolean          @default(false) @map("is_read")
  bookingId            String?          @map("booking_id")
  maintenanceRequestId String?          @map("maintenance_request_id")
  createdAt            DateTime         @default(now()) @map("created_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking            Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ── System Settings ──────────────────────────────────────────

model SystemSetting {
  id                  String   @id @default(uuid())
  companyName         String   @map("company_name")
  companyLogo         String?  @map("company_logo")
  address             String?
  timezone            String   @default("UTC")
  dateFormat          String   @default("YYYY-MM-DD") @map("date_format")
  currency            String   @default("USD")
  language            String   @default("en")
  theme               String   @default("dark")
  
  // Audit configurations
  auditRetentionDays  Int      @default(90) @map("audit_retention_days")
  auditLogLevel       String   @default("INFO") @map("audit_log_level")
  auditEnabledModules String[] @default(["AUTH", "DEPARTMENT", "EMPLOYEE"]) @map("audit_enabled_modules")
  
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ── Permissions ──────────────────────────────────────────────

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}
