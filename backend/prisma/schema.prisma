// ─────────────────────────────────────────────────────────────
// AssetFlow — Prisma Schema
// Phase 6: Platform Administration & Configuration
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

// ── Role ─────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// ── User ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  fullName      String    @map("full_name")
  email         String    @unique
  password      String
  phone         String
  profileImage  String?   @map("profile_image")
  roleId        String    @map("role_id")
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Organization Setup fields
  employeeCode String?   @unique @map("employee_code")
  departmentId String?   @map("department_id")
  designation  String?
  joiningDate  DateTime? @map("joining_date")

  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  // Relations
  department       Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDepartment Department? @relation("DepartmentHead")

  // Shared Infrastructure relations
  activityLogs      ActivityLog[]
  notifications     Notification[]
  assetAllocations  AssetAllocation[] @relation("AssetAllocationEmployee")
  allocationsMade   AssetAllocation[] @relation("AssetAllocationAllocator")
  bookings          Booking[]

  @@map("users")
}

// ── Refresh Token ────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Department ───────────────────────────────────────────────

model Department {
  id                 String           @id @default(uuid())
  name               String
  code               String           @unique
  description        String?
  parentDepartmentId String?          @map("parent_department_id")
  departmentHeadId   String?          @unique @map("department_head_id")
  status             DepartmentStatus @default(ACTIVE)
  isDeleted          Boolean          @default(false) @map("is_deleted")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // Relations
  parentDepartment Department?  @relation("SubDepartments", fields: [parentDepartmentId], references: [id])
  childDepartments Department[] @relation("SubDepartments")
  departmentHead   User?        @relation("DepartmentHead", fields: [departmentHeadId], references: [id])
  employees        User[]       @relation("DepartmentEmployees")
  assets           Asset[]

  @@map("departments")
}

// ── Asset Category ───────────────────────────────────────────

model AssetCategory {
  id               String         @id @default(uuid())
  name             String         @unique
  description      String?
  icon             String?
  requiresWarranty Boolean        @default(false) @map("requires_warranty")
  status           CategoryStatus @default(ACTIVE)
  isDeleted        Boolean        @default(false) @map("is_deleted")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_categories")
}

// ── Activity Log ─────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  action      String   // e.g. "LOGIN", "LOGOUT", "CREATE", "UPDATE", "ROLE_CHANGE"
  module      String   // e.g. "AUTH", "DEPARTMENT", "EMPLOYEE"
  entityId    String?  @map("entity_id")
  description String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ── Notification ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO") // e.g. "INFO", "ALERT", "SUCCESS", "WARNING"
  userId    String   @map("user_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── System Settings ──────────────────────────────────────────

model SystemSetting {
  id                  String   @id @default(uuid())
  companyName         String   @map("company_name")
  companyLogo         String?  @map("company_logo")
  address             String?
  timezone            String   @default("UTC")
  dateFormat          String   @default("YYYY-MM-DD") @map("date_format")
  currency            String   @default("USD")
  language            String   @default("en")
  theme               String   @default("dark")
  
  // Audit configurations
  auditRetentionDays  Int      @default(90) @map("audit_retention_days")
  auditLogLevel       String   @default("INFO") @map("audit_log_level")
  auditEnabledModules String[] @default(["AUTH", "DEPARTMENT", "EMPLOYEE"]) @map("audit_enabled_modules")
  
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ── Permissions ──────────────────────────────────────────────

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique // e.g. "Department.Create", "Employee.View"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ── Asset Status & Allocation Status ─────────────────────────

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

// ── Asset ────────────────────────────────────────────────────

model Asset {
  id              String      @id @default(uuid())
  code            String      @unique
  name            String
  description     String?
  serialNumber    String?     @unique @map("serial_number")
  categoryId      String      @map("category_id")
  status          AssetStatus @default(AVAILABLE)
  location        String?
  departmentId    String?     @map("department_id")
  acquisitionDate DateTime?   @map("acquisition_date")
  acquisitionCost Decimal?    @map("acquisition_cost")
  condition       String?     @default("New")
  sharedBookable  Boolean     @default(false) @map("shared_bookable")
  imageUrl        String?     @map("image_url")
  warrantyExpiry  DateTime?   @map("warranty_expiry")
  notes           String?
  isDeleted       Boolean     @default(false) @map("is_deleted")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  category          AssetCategory      @relation(fields: [categoryId], references: [id])
  department        Department?        @relation(fields: [departmentId], references: [id])
  allocations       AssetAllocation[]
  maintenanceRecords MaintenanceRecord[]
  bookings          Booking[]

  @@map("assets")
}

// ── Asset Allocation ─────────────────────────────────────────

model AssetAllocation {
  id               String           @id @default(uuid())
  assetId          String           @map("asset_id")
  employeeId       String           @map("employee_id")
  allocatedAt      DateTime         @default(now()) @map("allocated_at")
  returnedAt       DateTime?        @map("returned_at")
  expectedReturnAt DateTime?        @map("expected_return_at")
  status           AllocationStatus @default(ACTIVE)
  notes            String?
  allocatedById    String           @map("allocated_by_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  asset       Asset @relation(fields: [assetId], references: [id])
  employee    User  @relation("AssetAllocationEmployee", fields: [employeeId], references: [id])
  allocatedBy User  @relation("AssetAllocationAllocator", fields: [allocatedById], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@map("asset_allocations")
}

// ── Booking ──────────────────────────────────────────────────

model Booking {
  id         String   @id @default(uuid())
  assetId    String   @map("asset_id")
  bookedById String   @map("booked_by_id")
  departmentId String? @map("department_id")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  purpose    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  asset    Asset @relation(fields: [assetId], references: [id])
  bookedBy User  @relation(fields: [bookedById], references: [id])

  @@index([assetId])
  @@index([bookedById])
  @@map("bookings")
}

// ── Maintenance Record ───────────────────────────────────────

model MaintenanceRecord {
  id          String   @id @default(uuid())
  assetId     String   @map("asset_id")
  type        String
  description String?
  date        DateTime @default(now())
  cost        Decimal? @default(0)
  notes       String?
  performedBy String?  @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("maintenance_records")
}
